# Local-development settings. Copy to `.env` and edit; pydantic-settings
# (in app/core/config.py) reads `MT_MVP_*` overrides on import.
#
# You do NOT need a `.env` file to run the app: every setting has a sensible
# default in `app/core/config.py`. Use `.env` only when you want overrides.

# MT engine: `ctranslate2` (default; needs converted weights under
# models/opus-mt-en-es-ct2) or `marian_hf` (slower, pure PyTorch).
# MT_MVP_MT_ENGINE=ctranslate2

# Force device. Defaults to CUDA if available, otherwise CPU.
# MT_MVP_DEVICE=cuda

# Turn on Qwen post-edit (loads a multi-GB model on first /translate; needs VRAM or MT_MVP_POSTEDIT_FORCE_CPU=true).
# MT_MVP_POSTEDIT_USE_QWEN=true

# Run Qwen on CPU so MT can use the GPU (single 12 GB card often OOMs if both on CUDA).
# MT_MVP_POSTEDIT_FORCE_CPU=true

# Picks the lighter Qwen variant. The 3B is the default; 7B is sharper but
# requires ~16 GB VRAM with fp16.
# MT_MVP_POSTEDIT_QWEN_MODEL=Qwen/Qwen2.5-3B-Instruct

# Glossary path override (rarely needed).
# MT_MVP_GLOSSARY_PATH=/app/glossary/en_es_shotblasting.json

# Mount Gradio demo UI inside FastAPI at /gradio (optional; Docker sets this).
# MT_MVP_ENABLE_GRADIO=1

# Hugging Face token for gated models / downloads (never commit). Same as
# HF_TOKEN. Used by eval scripts after ``app.hf_env.load_root_dotenv()``.
# HUGGINGFACE_HUB_TOKEN=hf_your_token_here
